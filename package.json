    "cloudflare": "^6.3.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
